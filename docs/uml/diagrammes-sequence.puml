@startuml Séquence 2 — Inscription d'un pèlerin

title Processus d'inscription d'un pèlerin

skinparam sequenceArrowThickness 2
skinparam roundcorner 8

actor "Commercial" as User
participant "React\n(Frontend)" as FE
participant "Express\n/api" as API
database "MongoDB" as DB

== Vérification / Création du client ==

User -> FE : Ouvre le formulaire d'inscription
FE -> API : GET /api/clients?search=<nom>
API -> DB : Client.find({ $text: ... })
DB --> API : Liste clients correspondants
API --> FE : { clients: [...] }
FE --> User : Affiche les clients trouvés

alt Client inexistant
  User -> FE : Clique "Nouveau client"
  FE -> API : POST /api/clients\n{ nom, prenom, telephone,\nnumeroPasseport, ... }
  API -> DB : Client.create(...)
  DB --> API : Client créé
  API --> FE : 201 { client }
  FE --> User : Client ajouté à la sélection
end

== Sélection du départ ==

FE -> API : GET /api/packages?statut=OUVERT
API -> DB : PackageK.find({ statut: 'OUVERT' })
DB --> API : Liste des départs disponibles
API --> FE : { packages: [...] }
FE --> User : Affiche les départs avec prix par chambre

User -> FE : Sélectionne un départ\n+ type de chambre
FE -> FE : Auto-remplit dates + montant\nselon prixDouble/Triple/...

== Création de l'inscription ==

User -> FE : Valide le formulaire
FE -> API : POST /api/reservations\n{ packageKId, clients[], typeChambre,\nmontantTotalDu, dateDepart, dateRetour, notes }
API -> API : Validation express-validator
API -> DB : PackageK.findById(packageKId)
DB --> API : Package trouvé (statut OUVERT)
API -> API : Vérifie quota disponible\n(placesReservees + nbClients ≤ quotaMax)

alt Quota insuffisant
  API --> FE : 400 { message: "Quota insuffisant" }
  FE --> User : Affiche erreur
else Quota OK
  API -> DB : Reservation.create(...)\nnumero = "INS-2026-001" (auto)
  API -> DB : PackageK.update\n(placesReservees += nbClients)
  DB --> API : Inscription créée
  API --> FE : 201 { reservation }
  FE --> User : Toast "Inscription créée"\nRedirection vers détail
end

@enduml

